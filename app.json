{
  "expo": {
    "name": "ConqueRun",
    "slug": "conqurun",
    "scheme": "conquerun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ConqueRun usa tu ubicación mientras grabas una carrera para medir distancia, ritmo y conquistar barrios.",
          "locationAlwaysAndWhenInUsePermission": "ConqueRun usa tu ubicación incluso con la pantalla apagada para grabar carreras completas.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ConqueRun usa Face ID para desbloquear tu sesión guardada."
        }
      ],
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      "@react-native-firebase/crashlytics",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.743879769903-aajbv22jpkgdd576mu4a18cle77qagal"
        }
      ],
      "expo-apple-authentication",
      "./plugins/withReactNativeMapsfix",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./firebase-native/GoogleService-Info.plist",
      "config": {},
      "entitlements": {
        "com.apple.developer.devicecheck.appattest-environment": "production",
        "com.apple.developer.applesignin": [
          "Default",
          "Default"
        ]
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ConqueRun usa tu ubicación mientras grabas una carrera para medir distancia, ritmo y conquistar barrios.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ConqueRun usa tu ubicación incluso con la pantalla apagada para grabar carreras completas.",
        "UIBackgroundModes": [
          "location"
        ],
        "NSPhotoLibraryUsageDescription": "ConqueRun usa tu galería para elegir fotos de perfil o grupo, que se revisan antes de publicarse.",
        "NSFaceIDUsageDescription": "ConqueRun usa Face ID para desbloquear tu sesión guardada.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["strava"]
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
