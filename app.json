        ]
      },
      "bundleIdentifier": "com.conquerun.app"
    },
    "android": {
      "googleServicesFile": "./firebase-native/google-services.json",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.conquerun.app",
      "config": {},
      "permissions": [
