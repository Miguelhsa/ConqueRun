rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.esAdmin == true;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Nickname: mínimo 3 chars, máximo 20, solo alfanuméricos y guion bajo
    function nicknameValido(nickname) {
      return nickname is string &&
        nickname.size() >= 3 &&
        nickname.size() <= 20 &&
        nickname.matches('^[a-zA-Z0-9_áéíóúÁÉÍÓÚñÑüÜ]+$');
    }

    // nicknameKey es la versión en minúsculas del nickname
    function nicknameClave(clave) {
      return clave is string &&
        clave.size() >= 3 &&
        clave.size() <= 20 &&
        clave.matches('^[a-z0-9_áéíóúñü]+$');
    }

    // Nombre de grupo: 1-40 chars, no vacío
    function nombreGrupoValido(nombre) {
      return nombre is string &&
        nombre.size() >= 1 &&
        nombre.size() <= 40;
    }

    // Descripción de grupo: vacía o máximo 120 chars
    function descripcionGrupoValida(desc) {
      return desc is string && desc.size() <= 120;
    }

    function fechaNacimientoValida(fecha) {
      return fecha is string &&
        fecha.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function validUserCreate(uid) {
      return isOwner(uid) &&
        !request.resource.data.keys().hasAny(['esAdmin']) &&
        (
          !request.resource.data.keys().hasAny(['nickname']) ||
          (
            nicknameValido(request.resource.data.nickname) &&
            getAfter(/databases/$(database)/documents/nicknames/$(request.resource.data.nickname.lower())).data.uid == uid
          )
        ) &&
        request.resource.data.keys().hasOnly([
          'nickname',
          'edad',
          'pais',
          'genero',
          'fotoPendiente',
          'usuariosBloqueados',
          'consentimientoUbicacionCarrera',
          'consentimientoUbicacionCarreraEn',
          'onboardingPendiente',
          'onboardingCompletado',
          'onboardingCompletadoEn',
          'ciudadActualId',
          'ciudadActualNombre',
          'marcasCiudadActualId',
          'paisCodigo',
          'notificacionSegmentoClave',
          'notificacionSegmentoEn',
          'eliminacionSolicitada',
          'eliminacionSolicitadaEn',
          'actualizadoEn'
        ]);
    }

    function validUserUpdate(uid) {
      return isOwner(uid) &&
        !changedKeys().hasAny(['esAdmin']) &&
        (
          !changedKeys().hasAny(['nickname']) ||
          (
            !('nickname' in resource.data) &&
            nicknameValido(request.resource.data.nickname) &&
            getAfter(/databases/$(database)/documents/nicknames/$(request.resource.data.nickname.lower())).data.uid == uid
          )
        ) &&
        changedKeys().hasOnly([
          'nickname',
          'pais',
          'genero',
          'fotoPerfil',
          'fotoPendiente',
          'fotoPerfilEstado',
          'fotoMotivoRechazo',
          'fotoRevisadaEn',
          'usuariosBloqueados',
          'consentimientoUbicacionCarrera',
          'consentimientoUbicacionCarreraEn',
          'onboardingPendiente',
          'onboardingCompletado',
          'onboardingCompletadoEn',
          'ciudadActualId',
          'ciudadActualNombre',
          'marcasCiudadActualId',
          'paisCodigo',
          'eliminacionSolicitada',
          'eliminacionSolicitadaEn',
          'notificacionSegmentoClave',
          'notificacionSegmentoEn',
          'actualizadoEn'
        ]) &&
        (
          !changedKeys().hasAny(['pais']) ||
          !('pais' in resource.data)
        ) &&
        (
          !changedKeys().hasAny(['genero']) ||
          !('genero' in resource.data)
        ) &&
        (
          !changedKeys().hasAny(['fotoPerfilEstado']) ||
          request.resource.data.fotoPerfilEstado in ['pendiente', 'aprobada', 'rechazada']
        );
    }

    function validPrivateDatosCreate() {
      return request.resource.data.keys().hasOnly([
          'fechaNacimiento',
          'fechaNacimientoGuardadaEn'
        ]) &&
        fechaNacimientoValida(request.resource.data.fechaNacimiento);
    }

    function validPrivateDatosUpdate() {
      return request.resource.data.fechaNacimiento == resource.data.fechaNacimiento &&
        changedKeys().hasOnly(['fechaNacimientoGuardadaEn']);
    }

    function validPrivateNotificacionesCreate() {
      return request.resource.data.keys().hasOnly(['pushToken']) &&
        request.resource.data.pushToken is string &&
        request.resource.data.pushToken.size() <= 512;
    }

    function validPrivateNotificacionesUpdate() {
      return changedKeys().hasOnly(['pushToken']) &&
        request.resource.data.pushToken is string &&
        request.resource.data.pushToken.size() <= 512;
    }

    function validGrupoCreate() {
      let userDoc = get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
      return signedIn() &&
        request.resource.data.creador == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'nombre',
          'descripcion',
          'esPublico',
          'codigo',
          'creador',
          'miembros',
          'nicknames',
          'ciudadId',
          'ciudadNombre',
          'foto',
          'fotoPendiente',
          'fotoEstado',
          'fotoMotivoRechazo',
          'fotoRevisadaEn',
          'puntosTotales',
          'carrerasTotales',
          'distanciaTotal',
          'duracionTotal',
          'creadoEn'
        ]) &&
        request.resource.data.miembros.size() == 1 &&
        request.resource.data.miembros.hasAll([request.auth.uid]) &&
        request.resource.data.puntosTotales == 0 &&
        request.resource.data.carrerasTotales == 0 &&
        request.resource.data.distanciaTotal == 0 &&
        request.resource.data.duracionTotal == 0 &&
        request.resource.data.esPublico is bool &&
        request.resource.data.codigo.matches('^[A-Z0-9]{6}$') &&
        request.resource.data.ciudadId == userDoc.ciudadActualId &&
        request.resource.data.ciudadNombre == userDoc.ciudadActualNombre &&
        request.resource.data.nicknames.keys().hasAll(request.resource.data.miembros) &&
        request.resource.data.miembros.hasAll(request.resource.data.nicknames.keys()) &&
        request.resource.data.nicknames[request.auth.uid] == userDoc.nickname &&
        request.resource.data.fotoPendiente == null &&
        request.resource.data.fotoMotivoRechazo == null &&
        (request.resource.data.foto == null || request.resource.data.fotoEstado == 'aprobada') &&
        (request.resource.data.foto != null || request.resource.data.fotoEstado == null) &&
        nombreGrupoValido(request.resource.data.nombre) &&
        descripcionGrupoValida(request.resource.data.descripcion);
    }

    function validGrupoMemberUpdate() {
      let userDoc = get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
      return signedIn() &&
        resource.data.esPublico == true &&
        userDoc.ciudadActualId == resource.data.ciudadId &&
        changedKeys().hasOnly(['miembros', 'nicknames']) &&
        !resource.data.miembros.hasAll([request.auth.uid]) &&
        request.resource.data.miembros.hasAll(resource.data.miembros) &&
        request.resource.data.miembros.hasAll([request.auth.uid]) &&
        request.resource.data.miembros.size() == resource.data.miembros.size() + 1 &&
        request.resource.data.nicknames.diff(resource.data.nicknames).affectedKeys().hasOnly([request.auth.uid]) &&
        request.resource.data.nicknames[request.auth.uid] == userDoc.nickname &&
        request.resource.data.nicknames.keys().hasAll(request.resource.data.miembros) &&
        request.resource.data.miembros.hasAll(request.resource.data.nicknames.keys());
    }

    function validGrupoLeave() {
      return signedIn() &&
        changedKeys().hasOnly(['miembros', 'nicknames']) &&
        resource.data.creador != request.auth.uid &&
        resource.data.miembros.hasAll([request.auth.uid]) &&
        !request.resource.data.miembros.hasAll([request.auth.uid]) &&
        request.resource.data.miembros.size() == resource.data.miembros.size() - 1 &&
        resource.data.miembros.hasAll(request.resource.data.miembros) &&
        request.resource.data.nicknames.diff(resource.data.nicknames).affectedKeys().hasOnly([request.auth.uid]) &&
        !request.resource.data.nicknames.keys().hasAll([request.auth.uid]) &&
        request.resource.data.nicknames.keys().hasAll(request.resource.data.miembros) &&
        request.resource.data.miembros.hasAll(request.resource.data.nicknames.keys());
    }

    function validGrupoKick() {
      return signedIn() &&
        resource.data.creador == request.auth.uid &&
        changedKeys().hasOnly(['miembros', 'nicknames']) &&
        request.resource.data.miembros.size() == resource.data.miembros.size() - 1 &&
        resource.data.miembros.hasAll(request.resource.data.miembros) &&
        request.resource.data.miembros.hasAll([resource.data.creador]) &&
        resource.data.nicknames.keys().hasAll(request.resource.data.nicknames.keys()) &&
        request.resource.data.nicknames.keys().hasAll(request.resource.data.miembros) &&
        request.resource.data.miembros.hasAll(request.resource.data.nicknames.keys());
    }

    function validGrupoOwnerUpdate() {
      return signedIn() &&
        resource.data.creador == request.auth.uid &&
        changedKeys().hasOnly([
          'nombre',
          'descripcion',
          'esPublico',
          'codigo',
          'fotoPendiente',
          'fotoEstado',
          'fotoMotivoRechazo',
          'fotoRevisadaEn'
        ]) &&
        (
          !changedKeys().hasAny(['fotoEstado']) ||
          request.resource.data.fotoEstado == 'pendiente'
        ) &&
        (
          !changedKeys().hasAny(['nombre']) ||
          nombreGrupoValido(request.resource.data.nombre)
        ) &&
        (
          !changedKeys().hasAny(['descripcion']) ||
          descripcionGrupoValida(request.resource.data.descripcion)
        ) &&
        (
          !changedKeys().hasAny(['esPublico']) ||
          request.resource.data.esPublico is bool
        ) &&
        (
          !changedKeys().hasAny(['codigo']) ||
          request.resource.data.codigo.matches('^[A-Z0-9]{6}$')
        );
    }

    function validRankingMetadataCreate(id) {
      return signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        id == request.resource.data.ciudadId + '_' + request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'uid', 'ciudadId', 'nickname', 'fotoPerfil', 'fotoPerfilEstado',
          'pais', 'genero', 'grupoEdad', 'ritmo30d', 'segmentoRitmo',
          'segmentoGenero', 'segmentoEdad', 'segmentoCompetitivo',
          'segmentoEtiqueta', 'topLogros', 'actualizadoEn'
        ]);
    }

    function validRankingMetadataUpdate(id) {
      return signedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.ciudadId == resource.data.ciudadId &&
        id == resource.data.ciudadId + '_' + request.auth.uid &&
        changedKeys().hasOnly([
          'nickname', 'fotoPerfil', 'fotoPerfilEstado',
          'pais', 'genero', 'grupoEdad', 'ritmo30d', 'segmentoRitmo',
          'segmentoGenero', 'segmentoEdad', 'segmentoCompetitivo',
          'segmentoEtiqueta', 'topLogros', 'actualizadoEn'
        ]);
    }

    // Rate limit de reportes: máximo 1 reporte por usuario por recurso
    function noReporteRepetido() {
      return !exists(/databases/$(database)/documents/reportes/$(request.auth.uid + '_' + request.resource.data.recursoId));
    }

    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if validUserCreate(uid) || isAdmin();
      allow update: if validUserUpdate(uid) || isAdmin();
      allow delete: if isAdmin();

      // Historial de ciudades visitadas
      match /ciudadesHistorico/{ciudadId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }

      // Marcas territoriales por barrio — subcolección sin límite de campos en el doc usuario
      match /marcasTerritoriales/{barrioId} {
        allow read: if isOwner(uid);
        allow write: if isAdmin();
      }

      // Datos privados: pushToken, fechaNacimiento — solo el propio usuario.
      // privado/strava contiene refresh tokens: bloqueado al cliente, solo Admin SDK.
      // Las notificaciones entre usuarios se gestionan desde Cloud Functions (Admin SDK).
      match /privado/{docId} {
        allow read: if isOwner(uid) && docId != 'strava';
        allow delete: if isOwner(uid) && docId == 'notificaciones';
        allow create: if isOwner(uid) && (
          (docId == 'datos' && validPrivateDatosCreate()) ||
          (docId == 'notificaciones' && validPrivateNotificacionesCreate())
        );
        allow update: if isOwner(uid) && (
          (docId == 'datos' && validPrivateDatosUpdate()) ||
          (docId == 'notificaciones' && validPrivateNotificacionesUpdate())
        );
      }
    }

    match /usuariosPublicos/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /carreras/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /barrios/{id} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /segmentos/{segmentoId} {
        allow read: if signedIn();
        allow create, update: if isAdmin();
      }
    }

    match /territorios/{id} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /segmentos/{segmentoId} {
        allow read: if signedIn();
        allow create, update: if isAdmin();
      }
    }

    match /ciudades/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /config/{id} {
      allow get: if id == 'app';
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /grupos/{id} {
      allow read: if isAdmin() ||
        (signedIn() && resource.data.esPublico == true) ||
        (signedIn() && request.auth.uid in resource.data.miembros);
      allow create: if validGrupoCreate();
      allow update: if validGrupoMemberUpdate() || validGrupoOwnerUpdate() || validGrupoLeave() || validGrupoKick() || isAdmin();
      allow delete: if isAdmin();
    }

    match /aportacionesGrupo/{id} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /rankingsCiudad/{id} {
      allow read: if signedIn();
      allow create: if isAdmin() || validRankingMetadataCreate(id);
      allow update: if isAdmin() || validRankingMetadataUpdate(id);
      allow delete: if isAdmin();
    }

    match /grupoMarcas/{grupoId} {
      allow read: if signedIn();
      match /marcasTerritoriales/{barrioId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }
    }

    // Permite collectionGroup queries sobre segmentos (barrios y territorios)
    match /{path=**}/segmentos/{segmentoId} {
      allow read: if signedIn();
    }

    match /reportes/{id} {
      allow create: if signedIn() &&
        noReporteRepetido() &&
        request.resource.data.keys().hasOnly([
          'tipo',
          'recursoId',
          'motivo',
          'reportadoPor',
          'estado',
          'creadoEn'
        ]) &&
        request.resource.data.reportadoPor == request.auth.uid &&
        request.resource.data.estado == 'pendiente' &&
        request.resource.data.tipo in ['usuario', 'grupo', 'carrera'] &&
        request.resource.data.motivo in ['contenido_inapropiado', 'trampa', 'spam'];
      allow read, update, delete: if isAdmin();
    }

    match /stravaOAuthNonces/{nonce} {
      allow read, write: if isAdmin();
    }

    match /solicitudesEliminacion/{id} {
      allow create: if signedIn() &&
        request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'estado',
          'solicitadoEn'
        ]) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.estado == 'pendiente';
      allow read, update, delete: if isAdmin();
    }

    match /nicknames/{nicknameKey} {
      allow get: if signedIn();
      allow create: if signedIn() &&
        nicknameClave(nicknameKey) &&
        request.resource.data.keys().hasOnly(['uid']) &&
        request.resource.data.uid == request.auth.uid &&
        getAfter(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nickname.lower() == nicknameKey;
      allow update: if signedIn() &&
        nicknameClave(nicknameKey) &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.keys().hasOnly(['uid']) &&
        request.resource.data.uid == request.auth.uid &&
        getAfter(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nickname.lower() == nicknameKey;
      allow delete: if isAdmin();
    }
  }
}
